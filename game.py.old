        player_shield_img = pygame.image.load(ship_path).convert_alpha()
        player_shield_img = pygame.transform.scale(player_shield_img, (200, 140))
        print(f"OK: {ships[chosen_ship]['name']} shield loaded!")
    except Exception as e:
        print(f"ERROR loading {ship_path}: {e}")
        player_shield_img = None

# Create masks
if player_img:
    player_mask = pygame.mask.from_surface(player_img)
if player_shield_img:
    player_shield_mask = pygame.mask.from_surface(player_shield_img)

