pygame.init()
pygame.mixer.init()
pygame.mixer.music.set_volume(0.4)

# --- Settings ---
BASE_URL = 'http://localhost:5000'
SCORE_URL = f'{BASE_URL}/score'
LEADERBOARD_URL = f'{BASE_URL}/leaderboard'
MYSCORE_URL = f'{BASE_URL}/myscore'

WIDTH, HEIGHT = 1200, 800
screen = pygame.display.set_mode((WIDTH, HEIGHT), pygame.RESIZABLE)
pygame.display.set_caption("The Crown of Externality")
clock = pygame.time.Clock()
font = pygame.font.SysFont("Arial", 28)

# Colors
BG       = (15, 15, 30)
PLAYER   = (0, 220, 255)
BALL     = (255, 80, 80)
COIN     = (255, 215, 0)
WHITE    = (255, 255, 255)
BULLET   = (180, 255, 180)
GREEN    = (80, 255, 80)
RED      = (255, 80, 80)

# --- Safe music helper ---
def play_music(track):
    """Switch to a different music track (ignores missing files).
       0 = menu music, 1 = gameplay music
    """
    filename = None
    if track == 0:
        filename = "music/start.wav"
    elif track == 1:
        filename = "music/game.wav"
    if filename and os.path.exists(filename):
        try:
            pygame.mixer.music.load(filename)
            pygame.mixer.music.play(-1)
        except Exception as e:
            print(f"Could not play {filename}: {e}")
    else:
        pygame.mixer.music.stop()
        if filename:
            print(f"Music file not found: {filename}")

# --- Procedural starfield ---
stars = []
for _ in range(300):
    speed = random.choice([1, 2, 3])
    brightness = 150 if speed == 1 else (220 if speed == 2 else 255)
    stars.append({
        "x": random.randint(0, WIDTH),
        "y": random.randint(0, HEIGHT),
        "speed": speed,
        "brightness": brightness
    })

