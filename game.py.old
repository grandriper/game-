player_bullet_img = None
if os.path.exists("bullet.png"):
    try:
        player_bullet_img = pygame.image.load("bullet.png").convert_alpha()
        player_bullet_img = pygame.transform.scale(player_bullet_img, (8, 16))
        print("OK: bullet.png loaded!")
    except Exception as e:
        print(f"ERROR loading bullet.png: {e}")

# --- Persistent save / load ---
SAVE_FILE = "save.json"
gold = 0
upgrades = {
    "speed": {"level": 0, "cost": 100, "effect": 1},
    "fire_rate": {"level": 0, "cost": 150, "effect": -2},
    "shield": {"level": 0, "cost": 200, "effect": 1},
}
tutorial_done = False
current_high_score = 0

def save_progress():
    data = {
        "gold": gold,
        "upgrades": upgrades,
        "high_score": current_high_score,
        "tutorial_done": tutorial_done
    }
    with open(SAVE_FILE, "w") as f:
        json.dump(data, f)

def load_progress():
    global gold, upgrades, current_high_score, tutorial_done
    if os.path.exists(SAVE_FILE):
        with open(SAVE_FILE, "r") as f:
            data = json.load(f)
            gold = data.get("gold", 0)
            upgrades = data.get("upgrades", {
                "speed": {"level": 0, "cost": 100, "effect": 1},
                "fire_rate": {"level": 0, "cost": 150, "effect": -2},
                "shield": {"level": 0, "cost": 200, "effect": 1},
            })
            current_high_score = data.get("high_score", 0)
            tutorial_done = data.get("tutorial_done", False)
    else:
        gold = 0
        upgrades = {
            "speed": {"level": 0, "cost": 100, "effect": 1},
            "fire_rate": {"level": 0, "cost": 150, "effect": -2},
            "shield": {"level": 0, "cost": 200, "effect": 1},
        }
        current_high_score = 0
        tutorial_done = False

load_progress()

# --- Login ---
username, token = login_flow(screen, clock, font)
if username is None:
    pygame.quit()
    sys.exit()

play_music(0)   # menu music (if available)

# --- Ship selection ---
ships = [
    {"name": "Alpha", "file": "alpha1.png"},
    {"name": "Beta",  "file": "beta1.png"},
    {"name": "Pie",   "file": "pie1.png"},
]
chosen_ship = 0

choosing = True
while choosing:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit(); sys.exit()
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_1: chosen_ship = 0; choosing = False
            if event.key == pygame.K_2: chosen_ship = 1; choosing = False
            if event.key == pygame.K_3: chosen_ship = 2; choosing = False

    if start_bg:
        screen.blit(start_bg, (0, 0))
    else:
        screen.fill(BG)
    title = font.render("CHOOSE YOUR SHIP", True, WHITE)
    screen.blit(title, (WIDTH//2 - 120, HEIGHT//2 - 100))
    for i, ship in enumerate(ships):
        txt = font.render(f"Press {i+1} for {ship['name']}", True, WHITE)
        screen.blit(txt, (WIDTH//2 - 120, HEIGHT//2 + i*40))
    pygame.display.flip()
    clock.tick(60)

# --- Load chosen ship sprites & masks ---
player_img = None
player_shield_img = None
player_mask = None
player_shield_mask = None
# Animation frames (to be filled later)
player_anim_frames = []
player_shield_anim_frames = []
anim_timer = 0
anim_index = 0
ANIM_SPEED = 10

# Hitbox dimensions (tight, 180x120 inside 200x140 sprite)
HITBOX_W = 180
HITBOX_H = 120
OFFSET_X = 10
OFFSET_Y = 10

ship_path = ships[chosen_ship]["file"]               # e.g. "alpha1.png"
base_path = ship_path.replace("1.png", ".png")       # "alpha.png"

# Load unshielded sprite (normal)
if os.path.exists(base_path):
    try:
        player_img = pygame.image.load(base_path).convert_alpha()
        player_img = pygame.transform.scale(player_img, (200, 140))
        print(f"OK: {ships[chosen_ship]['name']} base loaded!")
    except Exception as e:
        print(f"ERROR loading {base_path}: {e}")
